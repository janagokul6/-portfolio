# LLM API Configuration
# Use either OpenAI or Google Gemini
LLM_PROVIDER=openai # or 'gemini'
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail SMTP Configuration
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Applicant Information
APPLICANT_NAME=ABC XYZ
APPLICANT_CONTACT=+91 000000000
RESUME_PATH=public/resume.pdf

# Optional: required when using external cron (e.g. cron-job.org); leave unset for local dev
CRON_SECRET=your_long_random_secret_here

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/job-email-scheduler

# Application Configuration
NODE_ENV=development

# Email Tracking Configuration (optional)
# APP_URL is required for tracking to work in production
APP_URL=https://your-app.vercel.app
# PORTFOLIO_URL enables click tracking — appended to every outgoing email
PORTFOLIO_URL=https://your-portfolio.com
